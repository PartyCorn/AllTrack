generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String
  nickname      String   @unique
  bio           String?
  avatarUrl     String?

  level         Int      @default(1)
  xp            Int      @default(0)

  isPrivate     Boolean  @default(false)

  titles        UserTitle[]
  franchises    Franchise[]
  titleCollaborations UserTitleCollaborator[] @relation("UserTitleCollaborators")
  franchiseCollaborations FranchiseCollaborator[] @relation("FranchiseCollaborators")
  achievements  UserAchievement[]
  notifications Notification[]
  sentFriendRequests    Friendship[] @relation("FriendshipRequester")
  receivedFriendRequests Friendship[] @relation("FriendshipAddressee")
  comments      Comment[]
  profileComments Comment[] @relation("ProfileComments")

  createdAt     DateTime @default(now())
}

model UserTitle {
  id            Int   @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])

  type          TitleType
  title         String
  description   String?
  coverUrl      String?
  externalUrl   String?

  totalUnits    Int?
  currentUnit   Int?     @default(0)
  favorite      Boolean  @default(false)
  dateStarted   DateTime?
  dateFinished  DateTime?
  isRevisit     Boolean  @default(false)
  revisitCount  Int      @default(0)

  status        Status
  rating        Int?
  note          String?

  franchiseId   Int?
  franchise     Franchise? @relation(fields: [franchiseId], references: [id])

  collaborators UserTitleCollaborator[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Franchise {
  id          Int      @id @default(autoincrement())
  name        String
  description String?

  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  titles        UserTitle[]
  collaborators FranchiseCollaborator[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model Achievement {
  id          Int   @id @default(autoincrement())
  code        String   @unique
  title       String
  description String
  icon        String
  xpReward    Int

  users       UserAchievement[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserAchievement {
  id             Int   @id @default(autoincrement())
  userId         Int
  achievementId  Int

  user           User        @relation(fields: [userId], references: [id])
  achievement    Achievement @relation(fields: [achievementId], references: [id])

  unlockedAt     DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  type      String   // e.g., 'achievement_unlocked'
  title     String
  message   String
  data      Json?    // Additional data

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Friendship {
  id          Int      @id @default(autoincrement())
  requesterId Int
  addresseeId Int
  status      FriendshipStatus @default(PENDING)

  requester   User     @relation("FriendshipRequester", fields: [requesterId], references: [id])
  addressee   User     @relation("FriendshipAddressee", fields: [addresseeId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  authorId  Int
  profileId Int
  content   String

  author    User     @relation(fields: [authorId], references: [id])
  profile   User     @relation("ProfileComments", fields: [profileId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@index([authorId])
}

model UserTitleCollaborator {
  id        Int   @id @default(autoincrement())
  titleId   Int
  userId    Int

  title     UserTitle @relation(fields: [titleId], references: [id], onDelete: Cascade)
  user      User      @relation("UserTitleCollaborators", fields: [userId], references: [id], onDelete: Cascade)

  joinedAt  DateTime  @default(now())

  @@unique([titleId, userId])
  @@index([userId])
}

model FranchiseCollaborator {
  id          Int   @id @default(autoincrement())
  franchiseId Int
  userId      Int

  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  user        User      @relation("FranchiseCollaborators", fields: [userId], references: [id], onDelete: Cascade)

  joinedAt    DateTime  @default(now())

  @@unique([franchiseId, userId])
  @@index([userId])
}

enum TitleType {
  MOVIE
  SERIES
  ANIME
  GAME
  BOOK
  OTHER
}

enum Status {
  PLANNED
  IN_PROGRESS
  COMPLETED
  DROPPED
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}