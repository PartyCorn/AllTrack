generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String
  nickname      String   @unique
  bio           String?
  avatarUrl     String?

  level         Int      @default(1)
  xp            Int      @default(0)

  isPrivate     Boolean  @default(false)

  titles        UserTitle[]
  franchises    Franchise[]
  achievements  UserAchievement[]

  createdAt     DateTime @default(now())
}

model UserTitle {
  id            Int   @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])

  type          TitleType
  title         String
  description   String?
  coverUrl      String?
  externalUrl   String?

  totalUnits    Int?
  currentUnit   Int?     @default(0)

  status        Status
  rating        Int?
  note          String?

  franchiseId   Int?
  franchise     Franchise? @relation(fields: [franchiseId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Franchise {
  id          Int      @id @default(autoincrement())
  name        String
  description String?

  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  titles      UserTitle[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Achievement {
  id          Int   @id @default(autoincrement())
  code        String   @unique
  title       String
  description String
  xpReward    Int

  users       UserAchievement[]
}

model UserAchievement {
  id             Int   @id @default(autoincrement())
  userId         Int
  achievementId  Int

  user           User        @relation(fields: [userId], references: [id])
  achievement    Achievement @relation(fields: [achievementId], references: [id])

  unlockedAt     DateTime @default(now())
}

enum TitleType {
  MOVIE
  SERIES
  ANIME
  GAME
  BOOK
}

enum Status {
  PLANNED
  WATCHING
  COMPLETED
  DROPPED
}